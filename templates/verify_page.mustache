{{!
    @template local_certhistory/verify_page

    Certificate verification page — search form and result.

    Context variables:
    * formaction string  - URL the form posts to
    * code       string  - current code value (may be empty)
    * result_notfound bool - set when code was searched but not found
    * result_valid    bool - set when a valid certificate was found
    * details    array  - rows of {label, value} for the certificate details table

    Example context (json):
    {
        "formaction": "/local/certhistory/verify.php",
        "code": "ABC123XYZ",
        "result_valid": true,
        "details": [
            {"label": "Certificate Holder", "value": "Jane Doe"},
            {"label": "Certificate", "value": "Course Completion"},
            {"label": "Course Name", "value": "Introduction to Moodle"},
            {"label": "Date Issued", "value": "1 January 2024"},
            {"label": "Code", "value": "ABC123XYZ"}
        ]
    }
}}
<form method="get" action="{{formaction}}" class="mb-4">
    <div class="input-group">
        <input type="text"
               name="code"
               value="{{code}}"
               class="form-control"
               placeholder="{{#str}}verifycode, local_certhistory{{/str}}">
        <div class="input-group-append">
            <button type="submit" class="btn btn-primary">
                {{#str}}verify, local_certhistory{{/str}}
            </button>
        </div>
    </div>
</form>

{{#result_notfound}}
<div class="alert alert-danger" role="alert">
    {{#str}}certificatenotfound, local_certhistory{{/str}}
</div>
{{/result_notfound}}

{{#result_valid}}
<div class="alert alert-success" role="alert">
    {{#str}}certificatevalid, local_certhistory{{/str}}
</div>
<table class="generaltable w-auto">
    <tbody>
        {{#details}}
        <tr>
            <th class="pr-4 text-right font-weight-bold">{{label}}</th>
            <td>{{value}}</td>
        </tr>
        {{/details}}
    </tbody>
</table>
{{/result_valid}}
